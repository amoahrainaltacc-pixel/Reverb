# ─────────────────────────────────────────────
#  Reverb Bot – Environment Variables
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Required: Your Discord bot token (from Discord Developer Portal)
BOT_TOKEN=your_discord_bot_token_here

# Command prefix (default: .)
PREFIX=.

# Your Discord user ID (right-click your name → Copy User ID)
OWNER_ID=0

# Auto-disconnect delay in seconds when voice channel is empty (default: 300)
AUTO_DISCONNECT_DELAY=300

# Maximum number of tracks in the queue (default: 100)
MAX_QUEUE_SIZE=100

# Default playback volume 0-100 (default: 50)
DEFAULT_VOLUME=50
